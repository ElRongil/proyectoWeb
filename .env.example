# Servidor
PORT=3000

# Base de datos
DB_URI=mongodb://localhost:27017/bildyapp

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_seguro
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP) — usa Mailtrap para desarrollo
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BildyApp <noreply@bildyapp.com>

# Cloudinary — almacenamiento de imágenes y PDFs
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Slack — notificaciones de errores 5XX
SLACK_WEBHOOK_URL=
